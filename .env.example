# Required
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Gemini evaluator
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_EVALUATOR_MODEL=gemini-3.1-flash-lite-preview
GEMINI_EVALUATOR_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-3.1-lite,gemini-2.5-flash-lite

# Optional: OpenAI model overrides
CHAT_MODEL=gpt-4o-mini
EVAL_MODEL=gpt-4o-mini

# Optional: notifications
PUSHOVER_TOKEN=your_pushover_token_here
PUSHOVER_USER=your_pushover_user_here
