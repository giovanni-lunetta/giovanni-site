---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume – Giovanni Lunetta" description="View and download Giovanni Lunetta's resume.">
    <section class="section">
        <div class="container animate-fade-in" style="max-width: 900px; margin: 0 auto; display: flex; flex-direction: column; align-items: center;">
            <div style="text-align: center; margin-bottom: var(--spacing-xl);">
                <h1 style="background: var(--grad-text-hero); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">My Resume</h1>
                <p class="hero-subtitle">
                    A summary of my experience, education, and skills.
                </p>
                <div style="margin-top: var(--spacing-md);">
                    <a href="/resume.pdf" download class="button primary pulse-glow">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Download PDF
                    </a>
                </div>
            </div>

            <div class="resume-wrapper animate-slide-up delay-200" style="width: 100%; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--border-light); background: var(--bg-card); box-shadow: var(--shadow-lg);">
                <iframe src="/resume.pdf" width="100%" height="800px" style="border: none; display: block;" loading="lazy"></iframe>
            </div>
        </div>
    </section>
</BaseLayout>
