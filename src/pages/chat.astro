---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Chat with Giovanni (AI)" description="Chat with an AI version of Giovanni Lunetta about his career, skills, and experience.">
	<section class="section">
		<div class="container">
			<div class="animate-fade-in">
				<h1 style="background: var(--grad-text-hero); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Chat with Giovanni (AI)</h1>
				<p class="hero-subtitle">
					This is an AI version of me, running on Hugging Face Spaces. Ask about my background, TLDP experience, projects, skills, hobbies, or what I'm looking for in my next role.
				</p>
			</div>

			<div class="chat-iframe-wrapper animate-slide-up delay-200">
				<iframe src="https://glunetta02-career-conversation.hf.space" frameborder="0"
					allow="clipboard-write; clipboard-read; fullscreen" title="Chat with Giovanni (AI)" loading="lazy"></iframe>
			</div>

			<p class="section-note animate-slide-up delay-300" style="margin-top: var(--spacing-xl); text-align: center;">
				Note: This chatbot reflects my real experience and interests, but it's still AI. If you'd like to talk directly, feel free to <a href="mailto:giovanni.lunetta@example.com" style="font-weight: 500;">reach out via email</a> or LinkedIn.
			</p>
		</div>
	</section>
</BaseLayout>
