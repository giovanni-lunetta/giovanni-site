---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Giovanni Lunetta – Data Scientist & Creator">
	<!-- Hero Section -->
	<section class="hero">
		<div class="container">
			<div class="hero-grid">
				<div class="hero-text">
					<h1 class="animate-fade-in" style="background: var(--grad-text-hero); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Hi, I'm Giovanni.</h1>
					<p class="hero-subtitle animate-slide-up delay-100">Data Scientist. Builder. Competitor. Creator.</p>

					<p class="animate-slide-up delay-200" style="color: var(--text-secondary); line-height: 1.8;">
						I'm a Data Scientist in the TLDP (Technology Leadership Development Program) at Johnson & Johnson,
						passionate about integrating AI into meaningful work and solving real problems. Always building, always learning.
					</p>

					<div class="hero-actions animate-slide-up delay-300">
						<a href="/chat" class="button primary pulse-glow">Chat with my AI twin</a>
						<a href="/hobbies" class="button secondary">Explore my hobbies</a>
					</div>
				</div>

				<!-- Quick Snapshot Card -->
				<aside class="card card-featured animate-fade-in delay-200">
					<h3>Quick Snapshot</h3>
					<div style="margin-bottom: var(--spacing-md);">
						<strong>Education</strong>
						<p style="margin-bottom: 0;">M.S. Data Science, B.A. Statistics & Political Science – UConn</p>
					</div>
					<div style="margin-bottom: var(--spacing-md);">
						<strong>Currently</strong>
						<p style="margin-bottom: 0;">Data Scientist @ J&J (TLDP)</p>
					</div>
					<div style="margin-bottom: var(--spacing-md);">
						<strong>Passions</strong>
						<p style="margin-bottom: 0;">AI, Sports, Pokémon, Building products</p>
					</div>
					<div style="margin-top: var(--spacing-lg); padding-top: var(--spacing-lg); border-top: 1px solid var(--border-light);">
						<a href="/chat" style="font-weight: 500;">Prefer to ask questions? → Talk to the AI version of me</a>
					</div>
				</aside>
			</div>
		</div>
	</section>

	<div class="container"><div class="section-divider"></div></div>

	<!-- About Section -->
	<section class="section">
		<div class="container">
			<h2 class="section-title animate-fade-in">A bit more about me</h2>

			<p class="animate-slide-up delay-100" style="font-size: 1.125rem; line-height: 1.8; max-width: 900px;">
				I believe in building useful things that optimize workflows and empower others. Whether it's analyzing surgical logs,
				understanding patient segments, or architecting RAG pipelines, I approach every problem as an opportunity to learn and create impact.
				I'm driven by a growth mindset, grounded in faith and relationships, and I'm obsessed with making AI accessible and practical.
				When I'm not coding or thinking about data, you'll find me competing in sports, collecting Pokémon cards, or pushing myself in the gym.
			</p>

			<div style="display: flex; flex-wrap: wrap; gap: var(--spacing-sm); margin-top: var(--spacing-xl);" class="animate-slide-up delay-200">
				<span class="tag">AI Enthusiast</span>
				<span class="tag">Data Scientist</span>
				<span class="tag">Product Builder</span>
				<span class="tag">Sports Fan</span>
				<span class="tag">Pokémon Collector</span>
				<span class="tag">Fitness</span>
				<span class="tag">Faith-Driven</span>
			</div>
		</div>
	</section>

	<div class="container"><div class="section-divider"></div></div>

	<!-- Projects Section -->
	<section id="projects" class="section">
		<div class="container">
			<h2 class="section-title animate-fade-in">Selected work & interests</h2>

			<div class="grid animate-fade-in delay-100">
				<article class="card">
					<div style="width: 48px; height: 48px; margin-bottom: var(--spacing-md); background: rgba(52, 211, 153, 0.15); border: 1px solid rgba(52, 211, 153, 0.4); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; color: #34D399;">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
							<rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
							<path d="M9 14l2 2 4-4"></path>
						</svg>
					</div>
					<h3 style="font-size: 1.25rem;">Surgical Workflow Analytics</h3>
					<p style="font-size: 0.95rem; color: var(--text-tertiary);">
						Clustering analysis and preference modeling from log data to support strategic planning.
						Transforming operational insights into actionable business intelligence.
					</p>
				</article>

				<article class="card">
					<div style="width: 48px; height: 48px; margin-bottom: var(--spacing-md); background: rgba(52, 211, 153, 0.15); border: 1px solid rgba(52, 211, 153, 0.4); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; color: #34D399;">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
							<circle cx="9" cy="7" r="4"></circle>
							<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
							<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
						</svg>
					</div>
					<h3 style="font-size: 1.25rem;">Rare Disease Patient Segmentation</h3>
					<p style="font-size: 0.95rem; color: var(--text-tertiary);">
						Feature engineering and clustering to understand treatment patterns and improve patient outcomes.
						Leveraging data to drive precision medicine initiatives.
					</p>
				</article>

				<article class="card">
					<div style="width: 48px; height: 48px; margin-bottom: var(--spacing-md); background: rgba(52, 211, 153, 0.15); border: 1px solid rgba(52, 211, 153, 0.4); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; color: #34D399;">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
							<line x1="8" y1="21" x2="16" y2="21"></line>
							<line x1="12" y1="17" x2="12" y2="21"></line>
							<path d="M7 8h4m-4 4h10"></path>
						</svg>
					</div>
					<h3 style="font-size: 1.25rem;">GenAI & Document Understanding</h3>
					<p style="font-size: 0.95rem; color: var(--text-tertiary);">
						RAG pipelines, structured extraction, and evaluation workflows.
						Harnessing generative AI to unlock insights from unstructured data.
					</p>
				</article>
			</div>

			<p style="margin-top: var(--spacing-2xl);" class="animate-slide-up delay-300">
				Want more detail? <a href="/chat" style="font-weight: 500;">Ask about them on the Chat page.</a>
			</p>
		</div>
	</section>
</BaseLayout>
