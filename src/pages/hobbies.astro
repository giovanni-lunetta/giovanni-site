---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Hobbies – Giovanni Lunetta" description="Explore Giovanni Lunetta's interests outside of work, including sports, Pokemon collecting, faith, and fitness.">
    <!-- Hobby Hero -->
    <section class="hobby-hero section">
        <div class="container animate-fade-in">
            <h1 style="background: var(--grad-text-hero); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Beyond the Screen</h1>
            <p style="font-size: 1.125rem; line-height: 1.8;">
                When I'm not writing code or analyzing data, I pour my energy into a few core passions. 
                Here's what keeps me busy, grounded, and always learning.
            </p>
        </div>
    </section>

    <div class="container"><div class="section-divider"></div></div>

    <section class="section">
        <div class="container">
            <div class="hobby-grid animate-fade-in delay-100">
                
                <!-- Sports -->
                <article class="hobby-card">
                    <div class="hobby-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6" />
                            <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18" />
                            <path d="M4 22h16" />
                            <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22" />
                            <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22" />
                            <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z" />
                        </svg>
                    </div>
                    <h2 class="hobby-title">Sports & Athletics</h2>
                    <div class="hobby-tags">
                        <span class="tag">Basketball</span>
                        <span class="tag">Football / Soccer</span>
                        <span class="tag">Table Tennis</span>
                        <span class="tag">Volleyball</span>
                    </div>
                    <p class="hobby-description">
                        I'm a highly competitive person and have always loved playing sports. 
                        Whether it's a pickup basketball game, joining an intramural soccer league, or mastering table tennis, I thrive on the competition, teamwork, and physical challenge.
                    </p>
                </article>

                <!-- Pokemon -->
                <article class="hobby-card">
                    <div class="hobby-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <circle cx="12" cy="12" r="3"></circle>
                            <line x1="12" y1="9" x2="12" y2="9.01"></line>
                            <line x1="3.1" y1="12" x2="9" y2="12"></line>
                            <line x1="15" y1="12" x2="20.9" y2="12"></line>
                        </svg>
                    </div>
                    <h2 class="hobby-title">Pokémon Collecting</h2>
                    <div class="hobby-tags">
                        <span class="tag">TCG</span>
                        <span class="tag">Sealed Investments</span>
                        <span class="tag">PSA</span>
                    </div>
                    <p class="hobby-description">
                        I've been collecting Pokémon cards since I was a kid. 
                        Recently, I've gotten back into the TCG as both a collector and a builder of a sealed investment portfolio. 
                        I enjoy the mix of nostalgia, deep market analysis, and the community.
                    </p>
                </article>

                <!-- Faith & Relationships -->
                <article class="hobby-card">
                    <div class="hobby-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
                        </svg>
                    </div>
                    <h2 class="hobby-title">Faith & Relationships</h2>
                    <div class="hobby-tags">
                        <span class="tag">Christianity</span>
                        <span class="tag">Family</span>
                        <span class="tag">Community</span>
                    </div>
                    <p class="hobby-description">
                        My faith is the foundation of who I am. 
                        I prioritize building strong, genuine relationships and investing time in my community. 
                        I believe in treating everyone with grace and serving others.
                    </p>
                </article>

                <!-- Gym -->
                <article class="hobby-card">
                    <div class="hobby-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m6.5 6.5 11 11" />
                            <path d="m21 21-1-1" />
                            <path d="m3 3 1 1" />
                            <path d="m18 22 4-4" />
                            <path d="m2 6 4-4" />
                            <path d="m3 10 7-7" />
                            <path d="m14 21 7-7" />
                        </svg>
                    </div>
                    <h2 class="hobby-title">Fitness</h2>
                    <div class="hobby-tags">
                        <span class="tag">Weightlifting</span>
                        <span class="tag">Consistency</span>
                    </div>
                    <p class="hobby-description">
                        The gym is my daily reset. Going to the gym is an exercise in discipline and consistency. 
                        It keeps me healthy and focused, demonstrating that steady effort over time yields the best results.
                    </p>
                </article>
                
            </div>
            
            <div class="text-center" style="margin-top: var(--spacing-2xl);">
                <p class="animate-slide-up delay-300">
                    Curious about any of these? <a href="/chat" style="font-weight: 500;">Ask my AI on the Chat page.</a>
                </p>
            </div>
        </div>
    </section>
</BaseLayout>
